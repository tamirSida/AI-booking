# --- OpenAI ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Verify the exact current model ID against https://platform.openai.com/docs/models
# before relying on this value. Design doc §9 calls for a low-latency GPT-5-family model.
OPENAI_MODEL=gpt-5.4-mini

# --- Phase 4 worker ---
# WebSocket URL where Twilio's Media Streams connect. Use the worker's ngrok wss:// URL.
WORKER_PUBLIC_URL=
# Realtime model.
OPENAI_REALTIME_MODEL=gpt-realtime

# --- Twilio ---
# https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164 format, e.g. +15551234567. Must support outbound calls to +972 (Israel).
TWILIO_PHONE_NUMBER=

# --- Telegram ---
# Create a bot via @BotFather, paste the token here.
TELEGRAM_BOT_TOKEN=
# Random secret you choose; Telegram sends it in the X-Telegram-Bot-Api-Secret-Token header.
TELEGRAM_WEBHOOK_SECRET=

# --- Firebase Admin (server SDK) ---
# Service account JSON, single-line. Generate via Firebase Console → Project settings → Service accounts.
# Escape newlines in the private key as \n.
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- Handoff target ---
# E.164 format. The hardcoded user phone number that gets dialed when payment handoff triggers (design doc §8.2).
USER_PHONE_NUMBER=

# --- Firebase web SDK (Phase 2+, exposed to browser via NEXT_PUBLIC_) ---
# Values come from Firebase Console → Project settings → General → "Your apps" → Web SDK config.
# Public by design; security comes from Firestore rules + Auth, not from hiding the apiKey.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
